# ── Server ────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────
# Get a free cluster at mongodb.com/cloud/atlas
MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/placemate?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────
# Any long random string — generate one at: https://www.uuidgenerator.net/
JWT_SECRET=your_super_secret_jwt_key_here_change_this

# ── Google OAuth ──────────────────────────────
# Create at console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ── Frontend URL (for CORS) ───────────────────
CLIENT_URL=http://localhost:5173
